{
    // settings related to the physical machine
    "machine": {
        "startPos": [128, 128, 9], // starting position of the nozzle
        "endPos": [128, 256], // final position of the nozzle
        "penOffset": [-38, 0], // position of the pen relative to the nozzle
        "plateSize": [256, 256], // size of the heatbed
        "drawableArea": [217, 243] // area of the paper the pen can safely move to
    },

    // controls the output gcode
    "gcode": {
        "heights": {"draw": 2, "travel": 3.5, "_segmentBounds": 2.1, "_pathBounds": 2.2, "_documentBounds": 2.3}, // mm
        "speeds": {"draw": 30, "travel": 250}, // mm/s
        "accels": {"draw": 3000, "travel": 15000}, // mm/s^2
        "shortTravelThreshold": 0.5, // travel moves below this distance will not lift the pen
        "tessellationTolerance": 0.012, // max allowed deviation (mm) of gcode from the true curve
        "maxTessellationDepth": 10, // cap on recursive curve fitting
        "infillSpacing": 0.3, // distance (mm) between concentric infill loops; <= 0 disables infill
        "loadDelay": 3, // wait this long for user to load pen

        "prefixFile": "gcode_templates/bambu_p1s_prefix.gcode",
        "suffixFile": "gcode_templates/bambu_p1s_suffix.gcode"
    },

    // controls how the gcode looks in bambu studio
    // these settings do not affect the printed result
    "visualization": {
        "penWidth": 0.35, // pen width in mm
        "lineTypes": {"draw": "Outer wall", "_segmentBounds": "Support transition", "_pathBounds": "Support interface", "_documentBounds": "Support"},
        "showPenPos": true, // if false, nozzle position will be shown in slicer
        "objectHeightChange": true, // if true, slightly increases the height of every other object so they show as seperate layers when viewed in the slicer

        "style": "line type", // options are "line type", "instruction", and "segment"
          // line type: shows role of lines in slicer view (styleLineOrder is ignored)
          // instruction: shows g1/g2/g3 instructions with different colors
          //  colors are set by the 1st 3 items in styleLineOrder
          //  other instructions will have their color as the last item in styleLineOrder
          // segment: shows each line segment as a different color
          //  colors are set by the items in styleLineOrder (last item is ignored)
        "styleLineOrder": ["Sparse infill", "Support interface", "Overhang wall", "Internal solid infill", "Gap infill"]
    },

    // debug settings
    "debug": {
        "showBoundingBoxes": false,
        "optimizePathOrder": true, // if false, path order will be the same as in the input file
        "profiling": false // if true, profiles the pipeline and prints the slowest functions
    }
}
