{
    // settings related to the physical machine
    "machine": {
        "startPos": [128, 128, 9], // starting position of the nozzle
        "penOffset": [-41, -9], // position of the pen relative to the nozzle
        "plateSize": [256, 256], // size of the heatbed
        "drawableArea": [215.9, 232] // areea of the paper the pen can safely move to
    },

    // controls the output gcode
    "gcode": {
        "heights": {"draw": 1, "travel": 4, "_segmentBounds": 1.1, "_pathBounds": 1.2, "_documentBounds": 1.3}, // mm
        "speeds": {"draw": 1800, "travel": 6000}, // mm/min
        "accels": {"draw": 3000, "travel": 10000}, // mm/s^2
        "shortTravelThreshold": 0.7, // travel moves below this distance will not lift the pen
        "avgTesselatedLineLength": 0.5, // average length per line on tesselated paths in mm

        "prefixFile": "Append/startCode.gcode",
        "suffixFile": "Append/endCode.gcode"
    },

    // controls how the gcode looks in bambu studio
    // these settings do not affect the printed result
    "visualization": {
        "penWidth": 0.7, // pen width in mm
        "lineTypes": {"draw": "Outer wall", "_segmentBounds": "Support transition", "_pathBounds": "Support interface", "_documentBounds": "Support"},
        "loadDelay": 20, // wait this long for user to load pen
        "showPenPos": true // if false, nozzle position will be shown in slicer
    },

    // debug settings
    "debug": {
        "showBoundingBoxes": false
    }
}
